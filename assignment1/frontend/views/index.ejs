<!DOCTYPE html>
<html><head><title>Banking App</title>
<style>
  body { font-family: Arial; max-width: 800px; margin: 50px auto; padding: 0 20px; }
  h1 { color: #1B4F72; } table { width: 100%; border-collapse: collapse; margin: 20px 0; }
  th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
  th { background: #1B4F72; color: white; }
  form { background: #f5f5f5; padding: 20px; border-radius: 8px; margin: 20px 0; }
  input { padding: 8px; margin: 5px; border: 1px solid #ddd; border-radius: 4px; }
  button { padding: 10px 20px; background: #2E86C1; color: white; border: none; border-radius: 4px; cursor: pointer; }
  .error { color: red; padding: 10px; background: #ffe0e0; border-radius: 4px; }
</style></head><body>
  <h1>Banking Application</h1>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <h2>Create Account</h2>
  <form action="/accounts" method="POST">
    <input name="name" placeholder="Full Name" required />
    <input name="email" placeholder="Email" type="email" required />
    <input name="balance" placeholder="Balance" type="number" step="0.01" value="0" />
    <button type="submit">Create</button>
  </form>
  <h2>Accounts (<%= accounts.length %>)</h2>
  <table><tr><th>ID</th><th>Name</th><th>Email</th><th>Balance</th></tr>
    <% accounts.forEach(a => { %>
      <tr><td><%= a.id %></td><td><%= a.name %></td><td><%= a.email %></td><td>$<%= a.balance.toFixed(2) %></td></tr>
    <% }); %>
  </table>
</body></html>